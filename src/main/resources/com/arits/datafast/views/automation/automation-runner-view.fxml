<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="com.arits.datafast.controller.automation.AutomationRunnerController"
            stylesheets="@../../style/pages/runner.css"
            styleClass="main-root">

    <top>
        <VBox>
            <fx:include source="../../components/header-view.fxml"/>
            <fx:include source="../../components/navbar-view.fxml"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="dashboard-scroll-pane"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox styleClass="runner-content" spacing="0">
                <padding>
                    <Insets top="28" right="60" bottom="48" left="60"/>
                </padding>

                <!-- ── Breadcrumb ── -->
                <HBox styleClass="breadcrumb-bar" alignment="CENTER_LEFT" spacing="6.0">
                    <Label fx:id="breadcrumbDashboard" text="Dashboard"
                           styleClass="breadcrumb-link" onMouseClicked="#handleBreadcrumbDashboard"/>
                    <FontIcon iconLiteral="gmi-chevron-right" iconSize="14"
                              styleClass="breadcrumb-sep"/>
                    <Label fx:id="breadcrumbModule" styleClass="breadcrumb-link"
                           onMouseClicked="#handleBreadcrumbModule"/>
                    <FontIcon iconLiteral="gmi-chevron-right" iconSize="14"
                              styleClass="breadcrumb-sep"/>
                    <Label fx:id="breadcrumbAutomationGroup" styleClass="breadcrumb-link"/>
                    <FontIcon iconLiteral="gmi-chevron-right" iconSize="14"
                              styleClass="breadcrumb-sep"/>
                    <Label fx:id="breadcrumbCurrent" styleClass="breadcrumb-current"/>
                </HBox>

                <!-- ── Page title row ── -->
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <VBox.margin>
                        <Insets top="12" bottom="28"/>
                    </VBox.margin>
                    <StackPane styleClass="runner-title-icon-wrap">
                        <FontIcon fx:id="titleIcon" iconLiteral="gmi-flash-on"
                                  iconSize="22" styleClass="runner-title-icon"/>
                    </StackPane>
                    <VBox spacing="3.0">
                        <Label fx:id="automationNameLabel" styleClass="runner-title"/>
                        <Label fx:id="automationDescLabel" styleClass="runner-subtitle"/>
                    </VBox>
                </HBox>

                <!-- ── Step progress bar ── -->
                <HBox fx:id="stepBar" styleClass="step-bar" alignment="CENTER_LEFT"
                      spacing="0">
                    <VBox.margin>
                        <Insets bottom="28"/>
                    </VBox.margin>

                    <!-- Step 1: Upload (active) -->
                    <HBox styleClass="step-item" alignment="CENTER_LEFT" spacing="8.0">
                        <StackPane styleClass="step-circle step-circle-active">
                            <FontIcon iconLiteral="gmi-file-upload" iconSize="15"
                                      styleClass="step-icon step-icon-active"/>
                        </StackPane>
                        <Label text="Upload" styleClass="step-label step-label-active"/>
                    </HBox>

                    <!-- Connector line -->
                    <Region styleClass="step-line" HBox.hgrow="ALWAYS"/>

                    <!-- Step 2: Map Columns (pending) -->
                    <HBox styleClass="step-item" alignment="CENTER_LEFT" spacing="8.0">
                        <StackPane styleClass="step-circle step-circle-pending">
                            <FontIcon iconLiteral="gmi-settings" iconSize="15"
                                      styleClass="step-icon step-icon-pending"/>
                        </StackPane>
                        <Label text="Map Columns" styleClass="step-label step-label-pending"/>
                    </HBox>

                    <!-- Connector line -->
                    <Region styleClass="step-line" HBox.hgrow="ALWAYS"/>

                    <!-- Step 3: Run (pending) -->
                    <HBox styleClass="step-item" alignment="CENTER_LEFT" spacing="8.0">
                        <StackPane styleClass="step-circle step-circle-pending">
                            <FontIcon iconLiteral="gmi-flash-on" iconSize="15"
                                      styleClass="step-icon step-icon-pending"/>
                        </StackPane>
                        <Label text="Run" styleClass="step-label step-label-pending"/>
                    </HBox>

                </HBox>

                <!-- ── Drop zone card ── -->
                <StackPane fx:id="dropZone" styleClass="drop-zone"
                           onDragOver="#handleDragOver"
                           onDragDropped="#handleDragDropped"
                           onDragEntered="#handleDragEntered"
                           onDragExited="#handleDragExited">

                    <VBox alignment="CENTER" spacing="12.0">
                        <padding>
                            <Insets top="64" right="40" bottom="64" left="40"/>
                        </padding>

                        <!-- Upload cloud icon -->
                        <StackPane styleClass="drop-icon-wrap">
                            <FontIcon iconLiteral="gmi-cloud-upload" iconSize="36"
                                      styleClass="drop-icon"/>
                        </StackPane>

                        <Label text="Upload your Excel file"
                               styleClass="drop-title"/>

                        <Label text="Click to browse and select a file"
                               styleClass="drop-subtitle"/>

                        <Button fx:id="chooseFileButton"
                                text="  Choose file"
                                styleClass="btn-choose-file"
                                onAction="#handleChooseFile">
                            <graphic>
                                <FontIcon iconLiteral="gmi-cloud-upload" iconSize="16"
                                          styleClass="btn-choose-file-icon"/>
                            </graphic>
                        </Button>

                        <Label text="Accepts .xlsx, .xlsm, .xls"
                               styleClass="drop-accepts"/>

                    </VBox>
                </StackPane>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../../components/footer-view.fxml"/>
    </bottom>

</BorderPane>