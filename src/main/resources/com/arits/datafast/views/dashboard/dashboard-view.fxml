<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="com.arits.datafast.controller.dashboard.DashboardController"
            stylesheets="@../../style/pages/dashboard.css"
            styleClass="main-root">

    <top>
        <VBox>
            <fx:include source="../../components/header-view.fxml"/>
            <fx:include source="../../components/navbar-view.fxml"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="dashboard-scroll-pane"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <StackPane alignment="TOP_CENTER">
                <VBox styleClass="dashboard-content" spacing="24.0" maxWidth="1320"
                      StackPane.alignment="TOP_CENTER">
                    <padding>
                        <Insets top="40" right="24" bottom="40" left="24"/>
                    </padding>

                    <Label text="All Portals" styleClass="section-heading"/>

                    <!-- Spinner shown while API call iss in flight -->
                    <HBox fx:id="loadingBox" alignment="CENTER_LEFT" spacing="10.0"
                          visible="true" managed="true">
                        <FontIcon iconLiteral="gmi-refresh" iconSize="18"
                                  styleClass="loading-spinner-icon"/>
                        <Label text="Loading portals..." styleClass="loading-label"/>
                    </HBox>

                    <!-- Shown on API failure -->
                    <HBox fx:id="errorBanner" styleClass="error-message-label"
                          alignment="CENTER_LEFT" spacing="8.0"
                          visible="false" managed="false">
                        <FontIcon iconLiteral="gmi-error" iconSize="16"
                                  styleClass="error-banner-icon"/>
                        <Label fx:id="errorLabel" styleClass="error-banner-text"
                               wrapText="true"/>
                    </HBox>

                    <!-- Cards injected at runtime by DashboardController -->
                    <FlowPane fx:id="moduleGrid"
                              styleClass="module-grid"
                              hgap="20.0"
                              vgap="20.0"
                              visible="false"
                              managed="false"/>

                </VBox>
            </StackPane>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../../components/footer-view.fxml"/>
    </bottom>

</BorderPane>