<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>
<BorderPane xmlns:fx="http://fxml"
            fx:controller="com.arits.datafast.controller.auth.ResetPasswordController"
            stylesheets="@../../style/pages/reset-password.css"
            prefHeight="700.0" prefWidth="900.0"
            styleClass="main-root">

    <top>
        <VBox>
            <fx:include source="../../components/header-view.fxml"/>
            <fx:include source="../../components/navbar-view.fxml"/>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" styleClass="login-background">
            <VBox styleClass="login-card" maxWidth="460.0" spacing="20.0" alignment="TOP_CENTER">
                <padding>
                    <Insets top="36" right="36" bottom="36" left="36"/>
                </padding>

                <!-- Icon + Heading -->
                <VBox spacing="12.0" alignment="CENTER">
                    <HBox alignment="CENTER">
                        <StackPane styleClass="otp-icon-circle">
                            <FontIcon iconLiteral="gmi-lock" iconSize="24" styleClass="otp-lock-icon"/>
                        </StackPane>
                    </HBox>
                    <Label text="Reset Password" styleClass="card-main-heading"/>
                    <Label text="Enter the 6-digit code sent to your email and create a new password for your account"
                           styleClass="card-sub-heading" wrapText="true" alignment="CENTER" textAlignment="CENTER"/>
                </VBox>

                <!-- Error banner -->
                <HBox fx:id="errorBanner" styleClass="error-message-label" alignment="CENTER_LEFT"
                      spacing="8.0" managed="false" visible="false">
                    <FontIcon iconLiteral="gmi-error" iconSize="16" styleClass="error-banner-icon"/>
                    <Label fx:id="errorLabel" styleClass="error-banner-text" wrapText="true"/>
                </HBox>

                <!-- 6 OTP boxes -->
                <HBox fx:id="otpContainer" alignment="CENTER" spacing="10.0">
                    <TextField fx:id="otp1" styleClass="otp-box" maxWidth="52" prefWidth="52" prefHeight="52"/>
                    <TextField fx:id="otp2" styleClass="otp-box" maxWidth="52" prefWidth="52" prefHeight="52"/>
                    <TextField fx:id="otp3" styleClass="otp-box" maxWidth="52" prefWidth="52" prefHeight="52"/>
                    <TextField fx:id="otp4" styleClass="otp-box" maxWidth="52" prefWidth="52" prefHeight="52"/>
                    <TextField fx:id="otp5" styleClass="otp-box" maxWidth="52" prefWidth="52" prefHeight="52"/>
                    <TextField fx:id="otp6" styleClass="otp-box" maxWidth="52" prefWidth="52" prefHeight="52"/>
                </HBox>

                <!-- Resend OTP -->
                <HBox alignment="CENTER_LEFT">
                    <Hyperlink fx:id="resendLink" text="Resend OTP (180s)"
                               onAction="#handleResendOtp" styleClass="resend-link"/>
                </HBox>

                <!-- New Password -->
                <VBox spacing="6.0">
                    <Label text="New Password" styleClass="input-field-label"/>
                    <HBox styleClass="custom-input-field" alignment="CENTER_LEFT" spacing="10.0">
                        <FontIcon iconLiteral="gmi-lock" iconSize="16" styleClass="input-icon"/>
                        <StackPane HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                            <PasswordField fx:id="newPasswordHidden" promptText="Create a strong password"
                                           styleClass="input-field-inner"/>
                            <TextField fx:id="newPasswordVisible" promptText="Create a strong password"
                                       styleClass="input-field-inner" visible="false" managed="false"/>
                        </StackPane>
                        <FontIcon fx:id="newPasswordToggle" iconLiteral="gmi-visibility-off"
                                  iconSize="16" styleClass="input-icon" onMouseClicked="#handleNewPasswordToggle"/>
                    </HBox>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="6.0">
                    <Label text="Confirm Password" styleClass="input-field-label"/>
                    <HBox styleClass="custom-input-field" alignment="CENTER_LEFT" spacing="10.0">
                        <FontIcon iconLiteral="gmi-lock" iconSize="16" styleClass="input-icon"/>
                        <StackPane HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                            <PasswordField fx:id="confirmPasswordHidden" promptText="Re-enter your password"
                                           styleClass="input-field-inner" HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="confirmPasswordVisible" promptText="Re-enter your password"
                                       styleClass="input-field-inner" visible="false" managed="false"
                                       HBox.hgrow="ALWAYS"/>
                        </StackPane>
                        <FontIcon fx:id="confirmPasswordToggle" iconLiteral="gmi-visibility-off"
                                  iconSize="16" styleClass="input-icon" onMouseClicked="#handleConfirmPasswordToggle"/>
                    </HBox>
                </VBox>

                <!-- Password requirements -->
                <VBox styleClass="password-requirements-box" spacing="6.0">
                    <Label text="Password requirements:" styleClass="requirements-heading"/>
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <FontIcon fx:id="req1Icon" iconLiteral="gmi-close" iconSize="14" styleClass="req-icon-fail"/>
                        <Label text="At least 8 characters" styleClass="req-label"/>
                    </HBox>
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <FontIcon fx:id="req2Icon" iconLiteral="gmi-close" iconSize="14" styleClass="req-icon-fail"/>
                        <Label text="At least one uppercase letter" styleClass="req-label"/>
                    </HBox>
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <FontIcon fx:id="req3Icon" iconLiteral="gmi-close" iconSize="14" styleClass="req-icon-fail"/>
                        <Label text="At least one number" styleClass="req-label"/>
                    </HBox>
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <FontIcon fx:id="req4Icon" iconLiteral="gmi-close" iconSize="14" styleClass="req-icon-fail"/>
                        <Label text="At least one special character" styleClass="req-label"/>
                    </HBox>
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <FontIcon fx:id="req5Icon" iconLiteral="gmi-close" iconSize="14" styleClass="req-icon-fail"/>
                        <Label text="Passwords match" styleClass="req-label"/>
                    </HBox>
                </VBox>

                <!-- Reset button -->
                <Button fx:id="resetButton" text="Reset Password" maxWidth="Infinity"
                        onAction="#handleReset" styleClass="primary-login-btn"/>

            </VBox>
        </VBox>
    </center>

    <bottom>
        <fx:include source="../../components/footer-view.fxml"/>
    </bottom>
</BorderPane>