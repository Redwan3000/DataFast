<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns:fx="http://fxml"
            fx:controller="com.arits.datafast.controller.auth.ForgetPasswordController"
            stylesheets="@../../style/application.css"
            prefHeight="700.0" prefWidth="900.0"
            styleClass="main-root">

    <top>
        <fx:include source="../../components/header-view.fxml"/>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="24.0" styleClass="login-background">
            <VBox styleClass="login-card" maxWidth="420.0" spacing="20.0" alignment="TOP_CENTER">
                <padding>
                    <javafx.geometry.Insets top="36" right="36" bottom="36" left="36"/>
                </padding>

                <VBox spacing="6.0" alignment="CENTER">
                    <Label text="Forgot password" styleClass="card-main-heading"/>
                    <Label text="Enter your email to receive a reset code" styleClass="card-sub-heading"/>
                </VBox>

                <VBox spacing="16.0" alignment="TOP_LEFT">
                    <VBox spacing="6.0">
                        <Label text="Email" styleClass="input-field-label"/>
                        <HBox styleClass="custom-input-field" alignment="CENTER_LEFT" spacing="10.0">
                            <FontIcon iconLiteral="gmi-email" iconSize="16" styleClass="input-icon"/>
                            <TextField fx:id="emailField" promptText="you@company.com"
                                       styleClass="input-field-inner" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>
                </VBox>

                <Button fx:id="sendButton" text="Send reset code" maxWidth="Infinity"
                        onAction="#handleSendCode" styleClass="primary-login-btn"/>

                <Hyperlink text="Back to login" onAction="#handleBackToLogin"
                           styleClass="forgot-password-link"/>
            </VBox>
        </VBox>
    </center>


    <bottom>
        <fx:include source="../../components/footer-view.fxml"/>
    </bottom>
</BorderPane>